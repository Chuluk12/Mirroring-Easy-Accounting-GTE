EASY_DB_HOST=192.168.10.5
EASY_DB_PORT=3999
EASY_DB_PATH=E:/EASY/GTE.EASY6
EASY_DB_USER=SYSDBA
EASY_DB_PASSWORD=replace-with-database-password
EASY_BACKEND_PORT=5000

# Secret untuk token internal Easy Dashboard, minimal 32 byte.
EASY_JWT_SECRET_KEY=replace-with-a-long-random-jwt-secret

# Satu atau beberapa API key, dipisahkan koma untuk mendukung rotasi key.
EASY_INTEGRATION_API_KEYS=replace-with-a-long-random-api-key

# Batas request per kombinasi API key dan alamat IP.
EASY_INTEGRATION_RATE_LIMIT_PER_MINUTE=120

# Origin browser yang diizinkan. Integrasi backend-to-backend tidak terkena CORS.
EASY_INTEGRATION_CORS_ORIGINS=https://calculator.gte.co.id
EASY_DASHBOARD_CORS_ORIGINS=*
EASY_LOG_LEVEL=INFO

# Aktifkan hanya bila aplikasi berada tepat di belakang reverse proxy tepercaya.
EASY_TRUST_PROXY=0

# Konfigurasi URL Redis untuk caching API (contoh: cache 10 menit untuk standarisasi)
# Jika tanpa password: redis://localhost:6379/0
# Jika menggunakan password: redis://:password_redis_kamu@localhost:6379/0
REDIS_URL=redis://localhost:6379/0
